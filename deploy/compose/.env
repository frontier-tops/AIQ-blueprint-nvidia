# ===========================================================================
# AIRA / AI-Q Research Assistant deployment config
# Used by `docker compose -f deploy/compose/docker-compose.yaml ...`
#
# IMPORTANT: Fill in the *_API_KEY values and the remote *_BASE_URL endpoints
# for your environment before running docker compose. DO NOT commit real
# secrets back to this file.
# ===========================================================================

# ---- API keys ----
NVIDIA_API_KEY=nvapi-REPLACE_WITH_YOUR_NVIDIA_API_KEY
NGC_API_KEY=nvapi-REPLACE_WITH_YOUR_NGC_API_KEY
TAVILY_API_KEY=tvly-REPLACE_WITH_YOUR_TAVILY_API_KEY

# ---- Host user for NIM cache ownership ----
# Run `id -u` to confirm; 1000 is the default for the `ubuntu` user.
USERID=1000

# ---- Local instruct LLM (this machine, 1x L40S) ----
# Switched from llama-3.3-70b-instruct (multi-GPU) to llama-3.1-8b-instruct (fits on a single L40S).
AIRA_INSTRUCT_LLM_IMAGE=nvcr.io/nim/meta/llama-3.1-8b-instruct:1.8.6
INSTRUCT_LLM_MODEL_NAME=meta/llama-3.1-8b-instruct
INSTRUCT_LLM_BASE_URL=http://aira-instruct-llm:8000/v1
AIRA_LLM_MS_GPU_ID=0

# ---- Remote nemotron (other machine) ----
NEMOTRON_LLM_MODEL_NAME=nvidia/llama-3.3-nemotron-super-49b-v1.5
NEMOTRON_LLM_BASE_URL=http://10.79.252.16:8999/v1

# ---- Remote RAG (other machine) ----
RAG_SERVER_URL=http://10.79.252.16:8081/v1
RAG_INGEST_URL=http://10.79.252.16:8082/v1

# ---- Backend / frontend ----
AIRA_HOSTED_NIMS=false
INFERENCE_ORIGIN=http://aira-backend:3838

# ---- NIM model cache (persists weights across container restarts) ----
MODEL_DIRECTORY=/home/ubuntu/.cache/model-cache
